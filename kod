<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Yılan Oyunu - Mobil Uyumlu</title>
    <style>
        body { margin: 0; overflow: hidden; background: #222; display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100vh; color: white; font-family: Arial; }
        canvas { border: 2px solid #fff; background: #000; touch-action: none; }
        #skor { font-size: 24px; margin-bottom: 10px; }
    </style>
</head>
<body>
    <div id="skor">Skor: 0</div>
    <canvas id="oyunAlani"></canvas>

    <script>
        const canvas = document.getElementById("oyunAlani");
        const ctx = canvas.getContext("2d");
        const gridSize = 20;
        canvas.width = window.innerWidth * 0.9;
        canvas.height = window.innerHeight * 0.8;

        let yilan = [{x: 100, y: 100}];
        let yon = {x: gridSize, y: 0};
        let yem = {x: 200, y: 200};
        let skor = 0;

        // Dokunmatik Kontrol (Sürükleme)
        let baslangicX, baslangicY;
        canvas.addEventListener('touchstart', e => {
            baslangicX = e.touches[0].clientX;
            baslangicY = e.touches[0].clientY;
        });

        canvas.addEventListener('touchmove', e => {
            let farkX = e.touches[0].clientX - baslangicX;
            let farkY = e.touches[0].clientY - baslangicY;
            if (Math.abs(farkX) > Math.abs(farkY)) {
                yon = {x: farkX > 0 ? gridSize : -gridSize, y: 0};
            } else {
                yon = {x: 0, y: farkY > 0 ? gridSize : -gridSize};
            }
        });

        function oyunDöngüsü() {
            let yeniKafa = {x: yilan[0].x + yon.x, y: yilan[0].y + yon.y};
            
            // Duvar kontrolü
            if (yeniKafa.x < 0 || yeniKafa.x >= canvas.width || yeniKafa.y < 0 || yeniKafa.y >= canvas.height) {
                alert("Oyun Bitti! Skorunuz: " + skor);
                yilan = [{x: 100, y: 100}]; skor = 0; document.getElementById("skor").innerText = "Skor: 0";
                return;
            }

            yilan.unshift(yeniKafa);
            
            if (yeniKafa.x === yem.x && yeniKafa.y === yem.y) {
                skor++;
                document.getElementById("skor").innerText = "Skor: " + skor;
                yem = {x: Math.floor(Math.random()*(canvas.width/gridSize))*gridSize, y: Math.floor(Math.random()*(canvas.height/gridSize))*gridSize};
            } else {
                yilan.pop();
            }

            // Çizim
            ctx.fillStyle = "black"; ctx.fillRect(0, 0, canvas.width, canvas.height);
            ctx.fillStyle = "red"; ctx.fillRect(yem.x, yem.y, gridSize-2, gridSize-2);
            ctx.fillStyle = "lime";
            yilan.forEach(p => ctx.fillRect(p.x, p.y, gridSize-2, gridSize-2));
        }

        setInterval(oyunDöngüsü, 100);
    </script>
</body>
</html>
